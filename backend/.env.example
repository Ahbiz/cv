# Backend Environment
# Copy to .env and fill in values: cp .env.example .env

PORT=8080
GEMINI_API_KEY=your_gemini_api_key_here
MONGODB_URI=mongodb://USER:PASS@shard0.xxx.mongodb.net:27017,shard1.xxx.mongodb.net:27017,shard2.xxx.mongodb.net:27017/autofillDB?tls=true&authSource=admin&retryWrites=true&w=majority

# Get a free Gemini key: https://aistudio.google.com/apikey
# Get a free MongoDB cluster: https://cloud.mongodb.com
# MongoDB Network Access: add 0.0.0.0/0 for Vercel
